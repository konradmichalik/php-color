{
	"name": "konradmichalik/php-color",
	"description": "A small, framework-agnostic PHP library for color conversion, luminance, contrast and deterministic string-to-color hashing.",
	"license": "GPL-2.0-or-later",
	"type": "library",
	"keywords": [
		"color",
		"hsl",
		"rgb",
		"hex",
		"contrast",
		"luminance",
		"wcag"
	],
	"authors": [
		{
			"name": "Konrad Michalik",
			"email": "hej@konradmichalik.dev",
			"homepage": "https://konradmichalik.dev",
			"role": "Maintainer"
		}
	],
	"require": {
		"php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0"
	},
	"require-dev": {
		"ergebnis/composer-normalize": "^2.42",
		"friendsofphp/php-cs-fixer": "^3.64",
		"phpstan/phpstan": "^2.0",
		"phpunit/phpunit": "^11.0 || ^12.0",
		"rector/rector": "^2.0",
		"shipmonk/composer-dependency-analyser": "^1.8"
	},
	"autoload": {
		"psr-4": {
			"KonradMichalik\\Color\\": "src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"KonradMichalik\\Color\\Tests\\": "tests/src"
		}
	},
	"config": {
		"allow-plugins": {
			"ergebnis/composer-normalize": true
		},
		"sort-packages": true
	},
	"scripts": {
		"check": [
			"@check:deps",
			"@check:refactor",
			"@check:static",
			"@check:style"
		],
		"check:coverage": [
			"@test:coverage",
			"@php build/check-coverage.php"
		],
		"check:deps": "composer-dependency-analyser --config build/checks/composer-dependency-analyser.php",
		"check:refactor": "@refactor --dry-run",
		"check:static": "phpstan analyse -c build/checks/phpstan.neon",
		"check:style": "@fix:style --dry-run",
		"ci": [
			"@composer validate --strict",
			"@check:deps",
			"@check:refactor",
			"@check:static",
			"@check:style"
		],
		"fix": [
			"@fix:composer",
			"@fix:style"
		],
		"fix:composer": "@composer normalize",
		"fix:style": "php-cs-fixer fix --config build/checks/.php-cs-fixer.php",
		"refactor": "rector process -c build/checks/rector.php",
		"test": "@test:coverage --no-coverage",
		"test:coverage": "phpunit -c build/tests/phpunit.xml"
	}
}
